    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "fumadocs-core": "^16.8.1",
    "gsap": "^3.15.0",
    "hast-util-from-html-isomorphic": "^2.0.0",
    "lenis": "^1.3.23",
    "lucide-react": "^0.577.0",
