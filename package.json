    "build": "next build",
    "build:search": "bun run scripts/build-search-index.ts",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier . --write "
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@expressive-code/plugin-line-numbers": "^0.41.7",
